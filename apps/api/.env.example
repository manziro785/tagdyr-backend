# ── Сервер ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8787

# ── База данных (Render Postgres external connection string) ──────────────────
# Пример: postgres://user:pass@host.render.com:5432/dbname?sslmode=require
DATABASE_URL=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=900          # 15 минут (секунды)
JWT_REFRESH_TTL=2592000     # 30 дней (секунды)

# ── CORS (белый список доменов фронта, через запятую) ────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Игровая логика (переопределяет дефолты движка; опционально) ───────────────
SAVINGS_RATE=0.08
DEFAULT_DEBT_RATE=0.14

# ── Наблюдаемость (опционально) ──────────────────────────────────────────────
SENTRY_DSN=
