{
  "name": "tagdyr-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Tagdyr (SimuLife 2.0) backend — shared engine, schemas and API",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "build": "tsc -b apps/api/tsconfig.json",
    "typecheck": "tsc -b apps/api/tsconfig.json",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "pnpm --filter @tagdyr/api dev",
    "db:generate": "pnpm --filter @tagdyr/api db:generate",
    "db:migrate": "pnpm --filter @tagdyr/api db:migrate",
    "db:studio": "pnpm --filter @tagdyr/api db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.0"
  }
}
